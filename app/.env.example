# Stacks network BitYield talks to. "testnet" (default) or "mainnet".
NEXT_PUBLIC_STACKS_NETWORK=testnet

# Hiro Stacks API base URL. Defaults to the public testnet/mainnet API for
# whichever network is selected above — only set this to point at a custom
# node or a higher rate-limit API key endpoint.
NEXT_PUBLIC_HIRO_API_URL=https://api.testnet.hiro.so

# Deployed YieldRouter contract, as "<address>.<contract-name>".
# See contracts/DEPLOYMENT.md for how to deploy and fill this in.
NEXT_PUBLIC_YIELD_ROUTER_ADDRESS=

# sBTC token contract, as "<address>.<contract-name>".
# See contracts/DEPLOYMENT.md for finding the real sBTC testnet contract
# (or using this project's mock-sbtc-token while testing).
NEXT_PUBLIC_SBTC_CONTRACT_ADDRESS=

# Server-only: private key for the account that pays STX fees on behalf of
# users via sponsored transactions (used by app/api/sponsor-tx).
# See contracts/DEPLOYMENT.md for how to create and fund this account.
# NEVER commit a real value for this.
SPONSOR_PRIVATE_KEY=
